# Production Environment Configuration for Raspberry Pi

# Application
NODE_ENV=production

# Database - PostgreSQL
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@mixer-db:5432/${DB_NAME}
DB_USER=recipe_user
DB_PASSWORD=secure-password-change-in-production
DB_NAME=recipe_manager

# JWT Secret for token signing (generate a secure random string locally)
JWT_SECRET=<generate-a-secure-random-string-locally-min-32-chars>

# NextAuth Configuration - HTTPS on Raspberry Pi
NEXTAUTH_URL=https://raspberrypi.local
NEXTAUTH_SECRET=<generate-a-secure-random-string-locally>

# API Configuration
NEXT_PUBLIC_API_BASE_URL=https://raspberrypi.local
CORS_ORIGIN=https://raspberrypi.local

# Logging
LOG_LEVEL=info
