{
  "cleanupPeriodDays": 30,
  "env": {
    "NODE_ENV": "development"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm install *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(docker compose *)",
      "Bash(sqlite3 *)",
      "Bash(gh *)",
      "Bash(ssh *)",
      "Bash(bash *)",
      "Bash(python3 *)",
      "Bash(pkill *)",
      "Bash(killall *)",
      "Bash(lsof *)",
      "Bash(kill *)",
      "Bash(jobs)",
      "Bash(sysctl *)",
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "WebSearch",
      "Bash(rm /Users/matthias/Claude_Code/mixer/.claude/CLAUDE.md && echo \"done\")",
      "Bash(git worktree *)",
      "Read(//Users/matthias/Claude Code/mixer/.claude/**)",
      "Bash(npm audit *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo *)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(git reset --hard HEAD~*)",
      "Bash(npm publish *)"
    ],
    "additionalDirectories": [
      "/private/tmp",
      "/Users/matthias/Claude_Code/mixer/.data",
      "/Users/matthias/Claude_Code/mixer/.claude"
    ]
  },
  "model": "claude-sonnet-4-6",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-tool-use.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-tool-use.sh"
          }
        ]
      }
    ]
  }
}
