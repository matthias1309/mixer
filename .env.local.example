# Local Development Setup
# Start PostgreSQL: npm run db:start
# Setup database: npm run db:setup
# Seed data: npm run db:seed
# Start app: npm run dev

# Database: local PostgreSQL (from docker-compose.local.yml)
DATABASE_URL=postgresql://recipe_user:local_password@localhost:5432/recipe_manager

# JWT Secret for token signing (change in production!)
JWT_SECRET=dev-secret-key-change-in-production

# Node environment
NODE_ENV=development

# API Base URL for frontend requests
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# CORS origin for API requests
CORS_ORIGIN=http://localhost:3000
